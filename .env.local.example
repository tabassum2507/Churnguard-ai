# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Internal API protection (generate with: openssl rand -hex 32)
INTERNAL_API_SECRET=your-secret-here

# HuggingFace Inference API — used by lib/embedder.js for runtime query embeddings.
# Free account at huggingface.co → Settings → Access Tokens → New Token (read scope).
# No credit card required. Free tier: ~30k tokens/month, plenty for query traffic.
HUGGINGFACE_API_KEY=hf_your_token_here

# Vapi
VAPI_API_KEY=your-vapi-api-key
VAPI_ASSISTANT_ID=your-vapi-assistant-id
VAPI_PHONE_NUMBER_ID=your-vapi-phone-number-id
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret   # optional — set in Vapi dashboard → Webhooks

# n8n webhooks (fill in after building each workflow)
N8N_ESCALATION_WEBHOOK=
